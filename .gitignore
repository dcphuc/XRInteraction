# This .gitignore is suitable for most Unity 3D projects.

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
MemoryCaptures/

# Auto-generated VS/JetBrains files
.vs/
.idea/
.gradle/
ExportedObj/
.consulo/

# Visual Studio / Rider files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity cache and generated metadata
sysinfo.txt
*.apk
*.aab
*.unitypackage

# Crash reports
crashlytics-build.properties

# Addressables (optional if generated)
ServerData/

# OS files
.DS_Store
Thumbs.db

# Keep Unity .meta files tracked
!*.meta